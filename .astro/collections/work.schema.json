{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string",
      "maxLength": 160
    },
    "role": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cover": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "repo": {
      "type": "string",
      "format": "uri"
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "summary",
    "role",
    "date"
  ]
}