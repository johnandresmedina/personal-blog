---
interface Props {
  eyebrow: string;
  count?: number;
}

const { eyebrow, count } = Astro.props;
---

<div class="border-line mb-8 flex items-baseline justify-between border-b pb-3">
  <h2 class="text-ink-soft font-mono text-xs tracking-[0.2em] uppercase">{eyebrow}</h2>
  {
    typeof count === 'number' && (
      <span class="text-ink-soft font-mono text-xs">({String(count).padStart(2, '0')})</span>
    )
  }
</div>
