---
import { SITE } from "@/site.config";

const year = new Date().getFullYear();
---

<footer class="border-line border-t">
  <div
    class="text-ink-soft mx-auto flex max-w-3xl flex-col gap-4 px-6 py-8 font-mono text-xs sm:flex-row sm:items-center sm:justify-between"
  >
    <p>© {year} by {SITE.name}. Built with Astro.</p>

    <nav class="flex items-center gap-4" aria-label="Social">
      {
        SITE.social.map((link) => (
          <a
            href={link.href}
            class="hover:text-signal transition-colors"
            rel="me"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</footer>
