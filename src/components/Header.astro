---
import ThemeToggle from '@/components/ThemeToggle.astro';
import { SITE, NAV_LINKS } from '@/site.config';
import { withBase } from '@/utils/url';

const currentPath = Astro.url.pathname;
---

<header class="border-line bg-paper/90 sticky top-0 z-40 border-b backdrop-blur">
  <div class="mx-auto flex max-w-3xl items-center justify-between gap-4 px-6 py-4">
    <a href={withBase('/')} class="font-display text-ink text-lg font-medium">
      {SITE.name}
    </a>

    <nav class="flex items-center gap-5" aria-label="Primary">
      {
        NAV_LINKS.map((link) => {
          const href = withBase(link.href);
          const isActive = currentPath === href || currentPath.startsWith(`${href}/`);
          return (
            <a
              href={href}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'font-mono text-xs tracking-wide uppercase transition-colors',
                isActive ? 'text-signal' : 'text-ink-soft hover:text-ink',
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
      <a
        href={withBase('/#contact')}
        class="text-ink-soft hover:text-ink hidden font-mono text-xs tracking-wide uppercase transition-colors sm:inline"
      >
        Contact
      </a>
      <ThemeToggle />
    </nav>
  </div>
</header>
