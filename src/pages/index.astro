---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import WorkRow from '@/components/WorkRow.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { SITE } from '@/site.config';
import { withBase } from '@/utils/url';

const allWork = await getCollection('work', ({ data }) => !data.draft);
const sorted = [...allWork].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featured = sorted.filter((entry) => entry.data.featured);
const rest = sorted.filter((entry) => !entry.data.featured);
const selected = [...featured, ...rest].slice(0, 5);
---

<BaseLayout title={SITE.name}>
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-20 sm:pt-24">
    <p class="text-ink-soft mb-6 inline-flex items-center gap-2 font-mono text-xs">
      <span class="bg-signal h-1.5 w-1.5 rounded-full" aria-hidden="true"></span>
      {SITE.status}
    </p>

    <h1 class="font-display text-ink max-w-2xl text-4xl leading-[1.1] font-medium sm:text-5xl">
      {SITE.tagline}
    </h1>

    <p class="text-ink-soft mt-6 max-w-md">
      {SITE.role} — based on the work below, not a list of buzzwords.
    </p>

    <div class="mt-8 flex flex-wrap items-center gap-3">
      <Button href={withBase('/work')} variant="solid">View the work →</Button>
      <Button href="#contact" variant="ghost">Say hello</Button>
    </div>
  </section>

  <section id="work" class="mx-auto max-w-3xl px-6 pb-20">
    <SectionHeading eyebrow="Selected work" count={allWork.length} />
    <div>
      {selected.map((entry) => <WorkRow entry={entry} />)}
    </div>
    {
      allWork.length > selected.length && (
        <div class="mt-6">
          <a
            href={withBase('/work')}
            class="text-ink-soft hover:text-signal font-mono text-xs transition-colors"
          >
            View all {allWork.length} projects →
          </a>
        </div>
      )
    }
  </section>

  <section id="about" class="mx-auto max-w-3xl px-6 pb-20">
    <SectionHeading eyebrow="About" />
    <p class="text-ink-soft max-w-xl">
      {SITE.description}
    </p>
    <a href={withBase('/about')} class="text-signal mt-4 inline-block font-mono text-xs hover:underline">
      More about how I work →
    </a>
  </section>

  <section id="contact" class="mx-auto max-w-3xl px-6 pb-24">
    <SectionHeading eyebrow="Let's talk" />
    <p class="font-display text-ink max-w-lg text-2xl sm:text-3xl">
      Have something worth building?
    </p>
    <a
      href={`mailto:${SITE.email}`}
      class="text-signal mt-4 inline-flex items-center gap-2 font-mono hover:underline"
    >
      {SITE.email}
    </a>
  </section>
</BaseLayout>
