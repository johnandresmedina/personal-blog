---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import WorkRow from '@/components/WorkRow.astro';
import SectionHeading from '@/components/SectionHeading.astro';

const allWork = (await getCollection('work', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout
  title="Work"
  description="Selected projects in product design and frontend engineering."
>
  <section class="mx-auto max-w-3xl px-6 pt-16 pb-24 sm:pt-24">
    <SectionHeading eyebrow="All work" count={allWork.length} />
    <div>
      {allWork.map((entry) => <WorkRow entry={entry} />)}
    </div>
  </section>
</BaseLayout>
