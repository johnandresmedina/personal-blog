---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/utils/url';
---

<BaseLayout title="Page not found">
  <section class="mx-auto flex max-w-3xl flex-col items-start gap-4 px-6 py-32">
    <p class="text-ink-soft font-mono text-xs tracking-[0.2em] uppercase">404</p>
    <h1 class="font-display text-ink text-3xl font-medium">This page doesn't exist.</h1>
    <p class="text-ink-soft">The link might be broken, or the page may have moved.</p>
    <a href={withBase('/')} class="text-signal font-mono text-sm hover:underline">← Back home</a>
  </section>
</BaseLayout>
