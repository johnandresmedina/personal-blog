{
  "name": "portfolio-starter",
  "type": "module",
  "version": "1.0.0",
  "private": false,
  "packageManager": "pnpm@11.13.0",
  "description": "A minimal, professional portfolio starter for Astro — TypeScript, Tailwind CSS v4, Content Collections, dark mode, and full SEO, with no unnecessary dependencies.",
  "keywords": [
    "astro",
    "astro-theme",
    "astro-template",
    "portfolio",
    "tailwindcss",
    "typescript",
    "starter"
  ],
  "license": "MIT",
  "author": "Bracozs",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/portfolio-starter"
  },
  "homepage": "https://github.com/your-username/portfolio-starter",
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
